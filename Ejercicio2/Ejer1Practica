class Bus:

    def __init__(self, capacidad):
        self.capacidad = capacidad
        self.pasajeros = 0
        self.dinero = 0

    def subir_pasajeros(self, x):
        if self.pasajeros + x <= self.capacidad:
            self.pasajeros += x
            print("Subieron", x, "pasajeros")
        else:
            print("No hay suficientes asientos")

    def cobrar_pasaje(self):
        self.dinero = self.pasajeros * 1.50
        print("Dinero recaudado:", self.dinero, "Bs")

    def asientos_libres(self):
        libres = self.capacidad - self.pasajeros
        print("Asientos disponibles:", libres)


#instancia
bus1 = Bus(40)

bus1.subir_pasajeros(25)
bus1.cobrar_pasaje()
bus1.asientos_libres()
