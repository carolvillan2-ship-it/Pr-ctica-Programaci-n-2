def promedio(vec):
    suma = 0
    for i in vec:
        suma += i
    return suma / len(vec)


def desviacion(vec):
    prom = promedio(vec)
    suma = 0
    for i in vec:
        suma += (i - prom)**2
    return (suma / (len(vec)-1))**0.5


vec = [0] * 10

for i in range(len(vec)):
    vec[i] = float(input(f"Ingrese el numero {i+1}: "))  

print(f"El promedio es: {promedio(vec)}")
print(f"La desviacion estandar es: {desviacion(vec)}")
